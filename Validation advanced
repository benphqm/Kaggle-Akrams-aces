origSummary <- function(data, lev = NULL, model = NULL) {
  
   # --- LOG SCALE METRICS ---
  SS_res_log <- sum((data$obs - data$pred)^2)
  SS_tot_log <- sum((data$obs - mean(data$obs))^2)
  R2_log <- 1 - SS_res_log / SS_tot_log
  
  # --- ORIGINAL SCALE METRICS ---
  obs_orig  <- exp(data$obs)
  pred_orig <- exp(data$pred + summary(model)$sigma^2 / 2)
  
  SS_res_orig <- sum((obs_orig - pred_orig)^2)
  SS_tot_orig <- sum((obs_orig - mean(obs_orig))^2)
  R2_orig <- 1 - SS_res_orig / SS_tot_orig
  
  RMSE_orig <- sqrt(mean((obs_orig - pred_orig)^2))
  
  
  
  c(
    Log_R2 = R2_log,
    Orig_R2 = R2_orig,
    Orig_RMSE = RMSE_orig
  )
}

get_coef_instability <- function(model_cv, data, model_formula) {
  
  coefs <- lapply(model_cv$control$index, function(train_idx) {
    fit <- lm(model_formula, data = data[train_idx, ])
    coef(fit)
  })
  
  coef_mat <- do.call(rbind, coefs)
  
  instability <- data.frame(
    Term = colnames(coef_mat),
    Mean = apply(coef_mat, 2, mean),
    SD = apply(coef_mat, 2, sd),
    CV = apply(coef_mat, 2, sd) / abs(apply(coef_mat, 2, mean))
  )
  
  instability
}

CrossValidation_TrainTest <- function(model, data = Train, number = 5, repeats = 5) {
  
  train$price_bin <- cut(
  log(train$SalePrice),
  breaks = quantile(log(train$SalePrice), probs = seq(0, 1, 0.1), na.rm = TRUE),
  include.lowest = TRUE
)

# --- Step 2: Identify extreme houses (> 10M) and treat separately ---
# These are only 14 rows, ensure each fold gets at least 1
  extreme_idx <- which(train$SalePrice > 1e7)
  non_extreme_idx <- setdiff(seq_len(nrow(train)), extreme_idx)

# --- Step 3: Create stratified folds for non-extreme houses ---
  non_extreme_bins <- train$price_bin[non_extreme_idx]
  non_extreme_folds <- createFolds(non_extreme_bins, k = 5, list = TRUE, returnTrain = TRUE)

# --- Step 4: Add extreme houses to folds evenly ---
# Distribute extreme houses across folds
  extreme_split <- split(extreme_idx, rep(1:5, length.out = length(extreme_idx)))
  stratified_index <- lapply(1:5, function(f) c(non_extreme_folds[[f]], extreme_split[[f]]))
  
  # --- Train control ---
  ctrl <- trainControl(
    method = "repeatedcv",
    number = number,
    repeats = repeats,
    summaryFunction = origSummary,
    savePredictions = "final",
    returnResamp = "all", 
    index = stratified_index
  )
  
  # --- Fit cross-validated model ---
  model_cv <- train(
    formula(model),
    data = data,
    method = "lm",
    trControl = ctrl,
    metric = "Orig_R2"
  )
  
  # --- Add AIC for final fitted model ---
  model_cv$results$AIC <- AIC(model_cv$finalModel)
  
  # --- Coefficient instability ---
  coef_instability <- get_coef_instability(
    model_cv = model_cv,
    data = data,
    model_formula = formula(model)
  )
  
  
  
# --- Fold-level diagnostics ---
  pred_df <- model_cv$pred
  resample_ids <- unique(pred_df$Resample)

  fold_stats <- lapply(resample_ids, function(rid) {
    fold_data <- pred_df[pred_df$Resample == rid, ]
    
    # Bias-corrected predictions for original scale
    sigma2 <- summary(model_cv$finalModel)$sigma^2
    pred_orig <- exp(fold_data$pred + sigma2 / 2)
    obs_orig <- exp(fold_data$obs)

    # Residuals
    residuals <- obs_orig - pred_orig

    # Fold R2 and RMSE
    SS_res <- sum(residuals^2)
    SS_tot <- sum((obs_orig - mean(obs_orig))^2)
    R2_orig <- 1 - SS_res / SS_tot
    RMSE_orig <- sqrt(mean(residuals^2))

    # Flag bad fold
    bad_fold <- R2_orig < 0.80

    # Return fold stats
    list(
      Resample = rid,
      Orig_R2 = R2_orig,
      RMSE = RMSE_orig,
      BadFold = bad_fold,
      Residuals = residuals,
      DataIdx = fold_data$rowIndex  # original row indices
    )
  })

  # --- Convert to structured data frame ---
  fold_stats_df <- do.call(rbind, lapply(fold_stats, function(x) {
    data.frame(
      Resample = x$Resample,
      Orig_R2 = x$Orig_R2,
      RMSE = x$RMSE,
      BadFold = x$BadFold
    )
  }))

  # --- List of residuals per fold for inspection ---
  fold_residuals <- setNames(lapply(fold_stats, function(x) x$Residuals), sapply(fold_stats, `[[`, "Resample"))

  # --- Return structured result ---
  list(
    model = model_cv,
    performance = model_cv$results,
    coef_instability = coef_instability,
    fold_stats = fold_stats_df,
    fold_residuals = fold_residuals,
    bad_folds = fold_stats_df$Resample[fold_stats_df$BadFold]
  )
}
